{
  "builds": [
    {
      "src": "server/package.json",
      "use": "@vercel/node",
      "config": { "distDir": "server" }
    },
    {
      "src": "client/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/src/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ]
}